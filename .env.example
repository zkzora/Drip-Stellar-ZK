# ─── Stellar-only deployment mode ────────────────────────────────────────────
# Set to "stellar" to enable Stellar-only frontend (hides all Solana UI/copy).
# Leave unset (or set to anything other than "stellar") for the normal Drip app.
# Vercel env var: NEXT_PUBLIC_APP_CHAIN = stellar
NEXT_PUBLIC_APP_CHAIN=

# Supabase — server-side only. Never prefix with NEXT_PUBLIC_.
# Used by app/api/waitlist/route.ts to insert into public.waitlist.
SUPABASE_URL=your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
